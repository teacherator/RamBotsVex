                                        \\\n  for (int iterator = 0; iterator < iterations; iterator++)\n// END V5 MACROS\n\n\n// Robot configuration code.\ncontroller Controller1 = controller(primary);\nmotor frontLeft = motor(PORT2, ratio18_1, false);\n\nmotor rearLeft = motor(PORT1, ratio18_1, false);\n\nmotor frontRight = motor(PORT9, ratio18_1, true);\n\nmotor rearRight = motor(PORT10, ratio18_1, true);\n\nmotor INTAKE = motor(PORT11, ratio18_1, false);\n\nmotor FeedingLeft = motor(PORT6, ratio18_1, false);\n\nmotor FeedingRight = motor(PORT7, ratio18_1, true);\n\ndigital_out Pneumatic = digital_out(Brain.ThreeWirePort.A);\n\n\n// generating and setting random seed\nvoid initializeRandomSeed(){\n  int systemTime = Brain.Timer.systemHighResolution();\n  double batteryCurrent = Brain.Battery.current();\n  double batteryVoltage = Brain.Battery.voltage(voltageUnits::mV);\n\n  // Combine these values into a single integer\n  int seed = int(batteryVoltage + batteryCurrent * 100) + systemTime;\n\n  // Set the seed\n  srand(seed);\n}\n\n\n\nvoid vexcodeInit() {\n\n  //Initializing random seed.\n  initializeRandomSeed(); \n}\n\n\n\n\n// Helper to make playing sounds from the V5 in VEXcode easier and\n// keeps the code cleaner by making it clear what is happening.\nvoid playVexcodeSound(const char *soundName) {\n  printf(\"VEXPlaySound:%s\\n\", soundName);\n  wait(5, msec);\n}\n\n\n\n// Generated code.\n\n\n\n// define variable for remote controller enable/disable\nbool RemoteControlCodeEnabled = true;\n\n\n\n// Include the V5 Library\n#include \"vex.h\"\n  \n// Allows for easier use of the VEX Library\nusing namespace vex;\n\n// User defined function\nvoid myblockfunction_Pneumatics_ON_For__Time_Seconds_ButtonPressed(double myblockfunction_Pneumatics_ON_For__Time_Seconds_ButtonPressed__Time, bool myblockfunction_Pneumatics_ON_For__Time_Seconds_ButtonPressed__ButtonPressed);\n// User defined function\nvoid myblockfunction_Pneumatics_OFF_For__Time_Seconds_ButtonPressed(double myblockfunction_Pneumatics_OFF_For__Time_Seconds_ButtonPressed__Time, bool myblockfunction_Pneumatics_OFF_For__Time_Seconds_ButtonPressed__ButtonPressed);\n// User defined function\nvoid myblockfunction_Intake_Speed(double myblockfunction_Intake_Speed__Speed);\n// User defined function\nvoid myblockfunction_Speed_Presets__Motors__3C_MotorsOn(bool myblockfunction_Speed_Presets__Motors__3C_MotorsOn__Motors);\n// User defined function\nvoid myblockfunction_Open__OpenR1_Close__CloseR2(bool myblockfunction_Open__OpenR1_Close__CloseR2__OpenR1, bool myblockfunction_Open__OpenR1_Close__CloseR2__CloseR2);\n\nint Screen_precision = 0, Console_precision = 0, Controller1_precision = 0;\n\nfloat myVariable, Speed;\n\nbool BroWhat;\n\n// User defined function\nvoid myblockfunction_Pneumatics_ON_For__Time_Seconds_ButtonPressed(double myblockfunction_Pneumatics_ON_For__Time_Seconds_ButtonPressed__Time, bool myblockfunction_Pneumatics_ON_For__Time_Seconds_ButtonPressed__ButtonPressed) {\n  if (myblockfunction_Pneumatics_ON_For__Time_Seconds_ButtonPressed__ButtonPressed) {\n    Pneumatic.set(true);\n    wait(myblockfunction_Pneumatics_ON_For__Time_Seconds_ButtonPressed__Time, seconds);\n  }\n}\n\n// User defined function\nvoid myblockfunction_Pneumatics_OFF_For__Time_Seconds_ButtonPressed(double myblockfunction_Pneumatics_OFF_For__Time_Seconds_ButtonPressed__Time, bool myblockfunction_Pneumatics_OFF_For__Time_Seconds_ButtonPressed__ButtonPressed) {\n  if (myblockfunction_Pneumatics_OFF_For__Time_Seconds_ButtonPressed__ButtonPressed) {\n    Pneumatic.set(false);\n    wait(myblockfunction_Pneumatics_OFF_For__Time_Seconds_ButtonPressed__Time, seconds);\n  }\n}\n\n// User defined function\nvoid myblockfunction_Intake_Speed(double myblockfunction_Intake_Speed__Speed) {\n  FeedingLeft.setVelocity((myblockfunction_Intake_Speed__Speed * Controller1.Axis2.position() + myblockfunction_Intake_Speed__Speed), percent);\n  FeedingRight.setVelocity((myblockfunction_Intake_Speed__Speed * Controller1.Axis2.position() + myblockfunction_Intake_Speed__Speed), percent);\n  INTAKE.setVelocity((myblockfunction_Intake_Speed__Speed * Controller1.Axis2.position() + myblockfunction_Intake_Speed__Speed), percent);\n  FeedingLeft.spin(reverse);\n  FeedingRight.spin(reverse);\n  INTAKE.spin(reverse);\n}\n\n// User defined function\nvoid myblockfunction_Speed_Presets__Motors__3C_MotorsOn(bool myblockfunction_Speed_Presets__Motors__3C_MotorsOn__Motors) {\n  if (myblockfunction_Speed_Presets__Motors__3C_MotorsOn__Motors) {\n    if (Controller1.ButtonUp.pressing()) {\n      Speed = -1.0;\n    }\n    if (Controller1.ButtonRight.pressing()) {\n      Speed = -0.75;\n    }\n    if (Controller1.ButtonDown.pressing()) {\n      Speed = -0.5;\n    }\n    if (Controller1.ButtonLeft.pressing()) {\n      Speed = -0.25;\n    }\n  }\n}\n\n// User defined function\nvoid myblockfunction_Open__OpenR1_Close__CloseR2(bool myblockfunction_Open__OpenR1_Close__CloseR2__OpenR1, bool myblockfunction_Open__OpenR1_Close__CloseR2__CloseR2) {\n  if (myblockfunction_Open__OpenR1_Close__CloseR2__OpenR1) {\n    frontLeft.spinToPosition(5.0, degrees, false);\n  }\n  if (myblockfunction_Open__OpenR1_Close__CloseR2__CloseR2) {\n    frontLeft.spinToPosition(-180.0, degrees, false);\n  }\n}\n\n// \"when started\" hat block\nint whenStarted1() {\n  INTAKE.setPosition(0.0, degrees);\n  Speed = -0.5;\n  while (true) {\n    myblockfunction_Speed_Presets__Motors__3C_MotorsOn(true);\n    frontLeft.setVelocity((Speed * (Controller1.Axis3.position() + (Controller1.Axis4.position() - Controller1.Axis1.position()))), percent);\n    frontLeft.spin(forward);\n    rearLeft.setVelocity((Speed * (Controller1.Axis3.position() - (Controller1.Axis4.position() + Controller1.Axis1.position()))), percent);\n    rearLeft.spin(forward);\n    frontRight.setVelocity((Speed * (Controller1.Axis3.position() - (Controller1.Axis4.position() - Controller1.Axis1.position()))), percent);\n    frontRight.spin(forward);\n    rearRight.setVelocity((Speed * (Controller1.Axis3.position() + (Controller1.Axis4.position() + Controller1.Axis1.position()))), percent);\n    rearRight.spin(forward);\n    myblockfunction_Intake_Speed(1.0);\n    myblockfunction_Pneumatics_ON_For__Time_Seconds_ButtonPressed(1.0, Controller1.ButtonX.pressing());\n    myblockfunction_Pneumatics_OFF_For__Time_Seconds_ButtonPressed(1.0, Controller1.ButtonB.pressing());\n  wait(5, msec);\n  }\n  return 0;\n}\n\n\nint main() {\n  // Initializing Robot Configuration. DO NOT REMOVE!\n  vexcodeInit();\n\n  // post event registration\n\n  // set default print color to black\n  printf(\"\\033[30m\");\n\n  // wait for rotation sensor to fully initialize\n  wait(30, msec);\n\n  whenStarted1();\n}","target":"Physical"}